				"reveal": "always",
				"panel": "shared"
			}
		},
		{
			"label": "build",
			"type": "shell",
			"command": "bun run build",
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			}
		},
		{
			"label": "check",
			"type": "shell",
			"command": "bun run check",
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			}
